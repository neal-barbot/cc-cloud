# Copy this file to .env and fill secrets locally. Never commit .env.

# Use mock mode for local contract testing without a Claude-compatible backend.
CLAUDE_HTTP_MOCK=true

# Claude-compatible provider settings.
# Keep tokens out of git. The value below is intentionally a placeholder.
ANTHROPIC_AUTH_TOKEN=replace-with-your-token
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Model routing.
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_REASONING_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash

# Claude Code runtime behavior.
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
DISABLE_AUTOUPDATER=1
ENABLE_TOOL_SEARCH=true

# HTTP service settings.
HOST=0.0.0.0
PORT=8765
CORS_ORIGINS=*
